{
  "ConnectionStrings": {
    "SmartTaskManager": "Server=(localdb)\\MSSQLLocalDB;Database=SmartTaskManagerDb;Integrated Security=True;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },
  "Database": {
    "EnableEfLogging": false,
    "EnableDetailedErrors": false,
    "EnableSensitiveDataLogging": false
  },
  "Seeding": {
    "EnableSampleData": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
